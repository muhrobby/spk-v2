# Database Configuration
# Connection string format: mysql://user:password@host:port/database
# For local development with Docker: mysql://root:password@localhost:3306/spk
DATABASE_URL=

# BetterAuth Configuration
# Secret key for signing tokens (generate with: openssl rand -hex 32)
BETTER_AUTH_SECRET=

# BetterAuth URL (base URL of your application)
# For local development: http://localhost:3000
BETTER_AUTH_URL=

# Node Environment
# Options: development, production, test
NODE_ENV=development


N8N_RANKING_WEBHOOK_URL=
